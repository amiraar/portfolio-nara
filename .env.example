# ============================================================
# .env.example — Copy to .env and fill in your values
# ============================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
MAX_HISTORY=15

# --- Database (Neon PostgreSQL) ---
# Connection pooling URL (for Prisma in serverless/app runtime)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15
# Direct connection URL (for Prisma Studio & migrations — no -pooler suffix)
DIRECT_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# --- NextAuth ---
NEXTAUTH_SECRET=your-random-secret-string
# Local:
NEXTAUTH_URL=http://localhost:3000
# Production (Railway):
# NEXTAUTH_URL=https://your-app.railway.app

# --- Owner credentials ---
OWNER_EMAIL=your@gmail.com
# Plain text for dev; for production use bcrypt hash:
# node -e "console.log(require('bcryptjs').hashSync('yourpassword', 12))"
OWNER_PASSWORD=your-password

# --- App ---
# Local:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production (Railway):
# NEXT_PUBLIC_SITE_URL=https://your-app.railway.app
