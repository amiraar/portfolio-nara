# ============================================================
# .env.example — Copy to .env and fill in your values
# ============================================================

# --- Google AI Studio (Kaia AI) ---
# Get your free API key at: https://aistudio.google.com/apikey
GOOGLE_AI_STUDIO_KEY=your-key-here

# Primary model (gemini-2.5-flash has free tier: 5 RPM, 20 RPD)
OPENAI_MODEL=gemini-2.5-flash
# OPENAI_MODEL=gemini-1.5-flash

MAX_HISTORY=15

# Comma-separated fallback models if primary fails
OPENAI_FALLBACK_MODELS=gemini-2.5-flash-preview-04-17,gemini-1.5-flash

# Retry config
OPENROUTER_MAX_RETRIES=3
OPENROUTER_RETRY_BASE_MS=800

# System prompt for Kaia — paste as a single line, use \n for line breaks.
KAIA_SYSTEM_PROMPT=

# --- Database (Neon PostgreSQL) ---
# Connection pooling URL (for Prisma in serverless/app runtime)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15
# Direct connection URL (for Prisma Studio & migrations — no -pooler suffix)
DIRECT_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# --- NextAuth ---
NEXTAUTH_SECRET=your-random-secret-string
# Local:
NEXTAUTH_URL=http://localhost:3000
# Production (vercel):
# NEXTAUTH_URL=https://your-app.vercel.app

# --- Owner credentials ---
OWNER_EMAIL=your@gmail.com
# Plain text for dev; for production use bcrypt hash:
# node -e "console.log(require('bcryptjs').hashSync('yourpassword', 12))"
OWNER_PASSWORD=your-password

# --- App ---
# Local:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production (vercel):
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# --- Pusher ---
PUSHER_APP_ID=your-app-id
PUSHER_KEY=your-key
PUSHER_SECRET=your-secret
PUSHER_CLUSTER=ap1
NEXT_PUBLIC_PUSHER_KEY=your-key
NEXT_PUBLIC_PUSHER_CLUSTER=ap1
